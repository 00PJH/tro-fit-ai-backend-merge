# ─────────────────────────────────────────────────────────────────────────────
# Tro-Fit AI Vision — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── 팀 협의로 제외하는 폴더 ──────────────────────────────────────────────────
venv/
doc/*
!doc/rom_doc/

# ── 모델 바이너리 (용량이 크므로 Git LFS 또는 별도 배포 권장) ─────────────────
# models/*.task
# models/*.tflite

# ── 추론 결과 이미지 / JSON (로컬 테스트용) ───────────────────────────────────
src/vision_ai/img_test/results/
src/vision_ai/mediapipe_rom_webcam_pipeline/results/

# ── 비디오 테스트 소스 제외 (대용량 파일) ───────────────────────────────────────
src/vision_ai/mediapipe_rom_webcam_pipeline/videos/*.mp4
!src/vision_ai/mediapipe_rom_webcam_pipeline/videos/shoulder_test.mp4
src/vision_ai/mediapipe_rom_webcam_pipeline/videos/*.avi
src/vision_ai/mediapipe_rom_webcam_pipeline/videos/*.mov

# ── Python 캐시 ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── 가상환경 (이름 변형 대비) ─────────────────────────────────────────────────
.venv/
env/
ENV/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── 기타 ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
rom_analysis_result.json
.env
users.db
